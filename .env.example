# Copy to .env (local) and set the same vars in Vercel → Project → Settings → Environment Variables.

# PostgreSQL connection string (Prisma Postgres, Supabase, Neon, RDS, …)
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Optional mirrors some hosts expect — safe to set to the same value as DATABASE_URL.
POSTGRES_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
PRISMA_DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# App
APP_NAME="Agency OS"

# Auth — generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-hex-string"

# Shared demo password for seeded accounts (remove/disable demo logins for real production)
DEMO_PASSWORD="agency123"
